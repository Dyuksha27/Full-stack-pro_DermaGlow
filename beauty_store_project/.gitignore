# ==========================================================
# DermaGlow Skincare Platform Master Root Gitignore
# ==========================================================

# Dependencies & Package Managers
**/node_modules/
**/jspm_packages/
.pnp
.pnp.js

# Local Environment Variable Secrets (CRITICAL SECURITY SAFETY)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.env

# Docker Cache Layers & Data Overlays
.docker/
**/.dockerignore

# Local Media Buffers & Skincare Asset uploads
# Ignores dynamic images uploaded by admins, keeping the layout clean
backend/uploads/products/*
!backend/uploads/products/.gitkeep

# Production Bundles & Compilation Distributables
**/dist/
**/build/
**/.out/
**/*.tsbuildinfo

# Diagnostics, Diagnostic Cache & System Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.vite-inspect

# System-Specific Desktop Context Metadata
.DS_Store
Thumbs.db
